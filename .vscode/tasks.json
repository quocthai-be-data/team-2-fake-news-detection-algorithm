{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Project",
      "type": "shell",
      "command": "g++",
      "args": ["-g", "-Wall", "-std=c++17", "src/*.cpp", "-o", "main.exe"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": ["$gcc"],
      "group": { "kind": "build", "isDefault": true }
    },
    {
      "label": "Build Active File (C++)",
      "type": "shell",
      "command": "g++",
      "args": ["-g", "-Wall", "-std=c++17", "${file}", "-o", "${fileDirname}/${fileBasenameNoExtension}.exe"],
      "options": { "cwd": "${fileDirname}" },
      "problemMatcher": ["$gcc"],
      "group": "build"
    }
  ]
}
